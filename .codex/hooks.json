{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$(git rev-parse --show-toplevel)/.codex/hooks/log_hook_input.py\"",
            "timeout": 30,
            "statusMessage": "Formatting edited files"
          }
        ]
      }
    ]
  }
}
