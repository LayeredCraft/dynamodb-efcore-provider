{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CLAUDE.local.md"
  ],
  "formatter": {
    "cs-jb-formatter": {
      "command": [
        "dotnet",
        "tool",
        "run",
        "jb",
        "cleanupcode",
        "--profile=Built-in: Reformat Code",
        "--include=$FILE",
        "--settings=EntityFrameworkCore.DynamoDb.sln.DotSettings",
      ],
      "extensions": [
        ".cs"
      ]
    },
    "mdformat": {
      "command": [
        "uv",
        "run",
        "mdformat",
        "$FILE"
      ],
      "extensions": [
        ".md"
      ]
    }
  }
}